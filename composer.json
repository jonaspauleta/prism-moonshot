{
    "name": "jonaspauleta/laravel-ai-moonshot",
    "description": "Moonshot AI (Kimi K2) provider for the official Laravel AI SDK.",
    "keywords": [
        "laravel",
        "laravel-ai",
        "laravel-ai-sdk",
        "moonshot",
        "kimi",
        "kimi-k2",
        "ai",
        "llm",
        "agent",
        "streaming",
        "tool-calling",
        "openai-compatible",
        "chat-completion",
        "generative-ai",
        "reasoning",
        "thinking-mode"
    ],
    "homepage": "https://github.com/jonaspauleta/laravel-ai-moonshot",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "João Paulo Santos", "email": "jpaulo4799santos@gmail.com", "role": "Developer" }
    ],
    "support": {
        "issues": "https://github.com/jonaspauleta/laravel-ai-moonshot/issues",
        "source": "https://github.com/jonaspauleta/laravel-ai-moonshot",
        "docs": "https://github.com/jonaspauleta/laravel-ai-moonshot#readme"
    },
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "laravel/ai": "~0.6.3"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Jonaspauleta\\LaravelAiMoonshot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jonaspauleta\\LaravelAiMoonshot\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint",
        "refactor": "vendor/bin/rector --no-diffs",
        "smoke": "@php bin/smoke.php",
        "quality": [
            "@refactor",
            "@format",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "extra": {
        "laravel": {
            "providers": ["Jonaspauleta\\LaravelAiMoonshot\\MoonshotServiceProvider"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
